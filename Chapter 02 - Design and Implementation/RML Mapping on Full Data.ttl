@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix m4i: <http://w3id.org/nfdi4ing/metadata4ing#> .
@prefix schema: <https://schema.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<#RunMapping>
  rml:logicalSource [
    rml:source "Data.json" ;
    rml:referenceFormulation ql:JSONPath ;
    rml:iterator "$[*]"
  ] ;

  rr:subjectMap [
    rr:template "https://www.example.org/run/{run_id}" ;
    rr:class m4i:Method
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rml:reference "run_id" ]
  ] ;

  # Link to parameters — IRI constructed here, no join needed
  rr:predicateObjectMap [
    rr:predicate m4i:hasParameter ;
    rr:objectMap [
      rr:template "https://www.example.org/run/{run_id}/param/{parameters[0].name}"
    ]
  ] ;

  # Link to metrics — same pattern
  rr:predicateObjectMap [
    rr:predicate m4i:investigates ;
    rr:objectMap [
      rr:template "https://www.example.org/run/{run_id}/metric/{metrics[0].name}"
    ]
  ] .

<#ParameterMapping>
  rml:logicalSource [
    rml:source "Data.json" ;
    rml:referenceFormulation ql:JSONPath ;
    rml:iterator "$[*]"                          # iterate runs, not parameters
  ] ;

  rr:subjectMap [
    # IRI matches exactly what <#RunMapping> links to above
    rr:template "https://www.example.org/run/{run_id}/param/{parameters[0].name}" ;
    rr:class schema:PropertyValue
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rml:reference "parameters[0].name" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate schema:value ;
    rr:objectMap [
      rml:reference "parameters[0].value" ;
      rr:datatype xsd:double
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate schema:unitCode ;
    rr:objectMap [
      rr:template "http://qudt.org/vocab/unit/{parameters[0].unit}" ;
      rr:termType rr:IRI
    ]
  ] .

<#MetricMapping>
  rml:logicalSource [
    rml:source "Data.json" ;
    rml:referenceFormulation ql:JSONPath ;
    rml:iterator "$[*]"                          # iterate runs, not metrics
  ] ;

  rr:subjectMap [
    rr:template "https://www.example.org/run/{run_id}/metric/{metrics[0].name}" ;
    rr:class schema:PropertyValue
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rml:reference "metrics[0].name" ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate schema:value ;
    rr:objectMap [
      rml:reference "metrics[0].value" ;
      rr:datatype xsd:double
    ]
  ] ;

  rr:predicateObjectMap [
    rr:predicate schema:unitCode ;
    rr:objectMap [
      rr:template "http://qudt.org/vocab/unit/{metrics[0].unit}" ;
      rr:termType rr:IRI
    ]
  ] .